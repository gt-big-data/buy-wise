{
  "manifest_version": 3,
  "name": "BuyWise",
  "version": "1.0.0",
  "description": "Smart shopping assistant",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "BuyWise"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
